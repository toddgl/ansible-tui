Screen {
        layout: vertical;
    }

#main {
    layout: horizontal;
    height: 1fr;
}

#hosts {
    width: 30%;
    border: round green;
}

#roles {
    width: 40%;
    border: round cyan;
}

#preview {
    border: round yellow;
    height: 5;
}

LoadingIndicator {
    background: $boost;
    color: $accent;
    border: double $accent;
    width: 30%;
    height: 5;
    /* Center it on screen */
    margin: 10 35; 
}
